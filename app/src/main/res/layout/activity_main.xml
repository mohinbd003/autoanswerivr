<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto Answer Speaker IVR"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Personal-use prototype: answers incoming calls, turns on speaker, and reads a saved message aloud."
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnSetDialer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Set as default phone app" />

        <Switch
            android:id="@+id/switchEnable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Enable auto answer" />

        <Switch
            android:id="@+id/switchSpeaker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Use speakerphone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Auto-answer delay (seconds)"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="2"
            android:inputType="number" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Message/script"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etScript"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:gravity="top|start"
            android:hint="Assalamu alaikum. This phone is using an automatic response. Please leave a short message after the beep."
            android:inputType="textMultiLine"
            android:minLines="8" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Save settings" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Note: this is not a true IVR. Caller keypad detection on normal SIM calls is not reliably available to third-party apps."
            android:textColor="@android:color/holo_red_dark" />

    </LinearLayout>
</ScrollView>